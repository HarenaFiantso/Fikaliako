{
  "name": "fikaliako",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write . && pnpm --filter api format",
    "format:check": "prettier --check . && pnpm --filter api format:check",
    "check-types": "turbo run check-types"
