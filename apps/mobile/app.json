{
  "expo": {
    "name": "Fikaliako",
    "slug": "fikaliako",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fikaliako",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "mg.fikaliako.mobile",
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "mg.fikaliako.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Fikaliako uses your location to find places to eat near you. Your position is never stored."
        }
      ],
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
